<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPRs"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="#FFFFFF" />

    <LinearLayout
        android:id="@+id/bannerOffline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFA726"
        android:paddingVertical="8dp"
        android:paddingHorizontal="16dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/tvBannerEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sin señal — mostrando datos guardados"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTituloCancha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cargando PRs..."
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#E0E0E0"
            android:paddingVertical="8dp"
            android:paddingHorizontal="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="Desc."
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="Norte"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="Este"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cota"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:textSize="14sp"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPRs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFFFFF"/>

            <ProgressBar
                android:id="@+id/progressBarPRs"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:visibility="gone"/>
        </FrameLayout>

        <Button
            android:id="@+id/btnImportarArchivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Importar archivo de coordenadas"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            app:cornerRadius="8dp"/>

        <Button
            android:id="@+id/btnVerMapa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver Mapa Satelital"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="12dp"
            app:cornerRadius="8dp"/>
    </LinearLayout>
</LinearLayout>