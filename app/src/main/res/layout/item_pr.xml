<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        android:background="?android:attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvDescriptor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="PR1"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvNorte"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="5828008.689"
            android:textColor="#333333"
            android:gravity="center"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvEste"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="254098.215"
            android:textColor="#333333"
            android:gravity="center"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvCota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="446.040"
            android:textColor="#333333"
            android:gravity="center"
            android:textSize="14sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvFechaModPR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Última mod: 2026-03-10"
        android:textSize="11sp"
        android:textColor="#888888"
        android:gravity="end"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"/>

</LinearLayout>