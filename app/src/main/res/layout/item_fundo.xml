<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreFundo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del Fundo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/tvCodigoFundo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Código: F001"
                android:layout_marginTop="6dp"
                android:textSize="14sp"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tvComuna"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comuna: Mulchén"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEliminarFundo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#E53935"
            android:contentDescription="Eliminar fundo"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>